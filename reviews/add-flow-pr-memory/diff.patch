+import { execSync } from 'child_process';
+import process from 'process';
+
+const VPS_IP = "34.173.151.127";
+const VPS_USER = "soyrico699";
+const REMOTE_PATH = "/home/soyrico699/next-js-supabase-starter";
+const SSH_KEY = "~/.ssh/google_compute_engine";
+const REVIEW_REPO = process.env.BIVENET_REVIEW_REPO || "grillcheeseayutla-source/bivenet-review";
+const REVIEW_REPO_BRANCH = process.env.BIVENET_REVIEW_BRANCH || "main";
+
+const [,, command, arg] = process.argv;
+
+// Helper to run commands
+function runCmd(cmd, returnOutput = false) {
+  try {
+    const output = execSync(cmd, { encoding: 'utf-8', stdio: returnOutput ? 'pipe' : 'inherit' });
+    return returnOutput ? output.trim() : true;
+  } catch (error) {
+    if (returnOutput) {
+        throw error;
+    }
+    return false;
+  }
+}
+
+// Validate ID
+function validateId(id) {
+  if (!id || !/^[a-zA-Z0-9._-]+$/.test(id)) {
+    console.error("❌ Error: ID de tarea inválido. Solo se permiten letras, números, guiones y puntos.");
+    console.error("Ejemplos válidos: setup-flow, ai-context-fix");
+    process.exit(1);
+  }
+}
+
+// Check remote branch existence
+function remoteBranchExists(id) {
+  try {
+    runCmd(`git fetch origin main`, true);
+    runCmd(`git fetch origin tarea/${id}`, true);
+    return true;
+  } catch (e) {
+    return false;
+  }
+}
+
+// Analyze impact based on diff
+function analyzeImpact(id) {
+  try {
+    const output = runCmd(`git diff --name-only origin/main...origin/tarea/${id}`, true);
+    const files = output.split('\n').filter(Boolean);
+    
+    let hasNextJs = false;
+    let hasProvision = false;
+    let hasWsp = false;
+
+    const nextJsPaths = ['app/', 'pages/', 'src/', 'components/', 'lib/', 'public/', 'styles/', 'next.config.', 'middleware.', 'tailwind.config.', 'tsconfig.json', 'package.json', 'package-lock.json', 'pnpm-lock.yaml', 'yarn.lock'];
+
+    for (const file of files) {
+      if (file.startsWith('provision-agent-v2/')) {
+        hasProvision = true;
+      } else if (file.startsWith('wsp-agent-v2/')) {
+        hasWsp = true;
+      } else {
+        for (const p of nextJsPaths) {
+          if (file.startsWith(p) || file === p) {
+            hasNextJs = true;
+            break;
+          }
+        }
+      }
+    }
+
+    return { files, hasNextJs, hasProvision, hasWsp };
+  } catch (e) {
+    console.error("❌ Error al comparar ramas. ¿Estás seguro de que existe origin/main y origin/tarea/" + id + "?");
+    process.exit(1);
+  }
+}
+
+if (command === 'save') {
+  validateId(arg);
+  console.log(`\n💾 Iniciando guardado para la tarea: ${arg}`);
+  
+  // Checkout branch
+  try {
+    runCmd(`git checkout -b tarea/${arg}`, true);
+  } catch (e) {
+    runCmd(`git checkout tarea/${arg}`, true);
+  }
+
+  const status = runCmd(`git status --porcelain`, true);
+  if (!status) {
+    console.log("No hay cambios nuevos que guardar.");
+  } else {
+    console.log(`Archivos modificados:\n${status}`);
+    runCmd(`git add .`);
+    runCmd(`git commit -m "wip: tarea ${arg}"`);
+  }
+
+  console.log("Subiendo rama a GitHub...");
+  runCmd(`git push -u origin tarea/${arg} --force-with-lease`);
+  console.log("✅ Tarea guardada y subida con éxito.");
+
+} else if (command === 'plan') {
+  validateId(arg);
+  
+  if (!remoteBranchExists(arg)) {
+    console.error(`\n❌ La rama origin/tarea/${arg} no existe. Ejecuta primero flow:save.`);
+    process.exit(1);
+  }
+
+  const impact = analyzeImpact(arg);
+
+  console.log(`\n[PLAN] tarea/${arg}\n`);
+  
+  if (impact.files.length > 0) {
+      console.log("Archivos modificados detectados:");
+      impact.files.forEach(f => console.log(`  - ${f}`));
+  } else {
+      console.log("No se detectaron diferencias con main.");
+  }
+
+  console.log("\nCambios detectados:");
+  console.log(`- provision-agent-v2: ${impact.hasProvision ? 'SÍ' : 'NO'}`);
+  console.log(`- wsp-agent-v2: ${impact.hasWsp ? 'SÍ' : 'NO'}`);
+  console.log(`- Next.js: ${impact.hasNextJs ? 'SÍ' : 'NO'}`);
+
+  console.log("\nAcciones en release:");
+  console.log(`- merge tarea/${arg} -> main`);
+  console.log("- push origin main");
+  console.log("- SSH al VPS");
+  console.log("- git pull origin main");
+  if (impact.hasProvision) {
+    console.log("- restart provision-agent-v2");
+    console.log("- health check provision-agent-v2");
+  }
+  if (impact.hasWsp) {
+    console.log("- restart wsp-agent-v2");
+    console.log("- health check wsp-agent-v2");
+  }
+  if (impact.hasNextJs) {
+    console.log("\n⚠️ ATENCIÓN: Se detectaron cambios en Next.js. Despliegue manual requerido en Vercel.");
+  }
+
+} else if (command === 'pr') {
+  validateId(arg);
+  
+  if (!remoteBranchExists(arg)) {
+    console.error(`\n❌ La rama origin/tarea/${arg} no existe. Ejecuta primero npm run flow:save ${arg}.`);
+    process.exit(1);
+  }
+
